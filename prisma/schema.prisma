// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/cli/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// جدول المستخدمين
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("medic") // leader, scout, medic, sector_lead, operations
  isActive  Boolean  @default(true)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  availabilities Availability[]
  schedules      Schedule[]
  sessions       Session[]
  auditLogs      AuditLog[]
  
  @@index([email])
  @@index([role])
}

// جدول الجداول الشهرية
model Schedule {
  id        String   @id @default(cuid())
  month     Int
  year      Int
  data      String   @default("{}")
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  updatedByUser User? @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([month, year])
  @@index([month, year])
  @@index([updatedBy])
}

// جدول التفرغات الشهرية
model Availability {
  id        String   @id @default(cuid())
  userId    String
  month     Int      // الشهر (1-12)
  year      Int      // السنة
  
  // فترات التفرغ لكل يوم من أيام الأسبوع (JSON string)
  sunday    String   @default("[]")
  monday    String   @default("[]")
  tuesday   String   @default("[]")
  wednesday String   @default("[]")
  thursday  String   @default("[]")
  friday    String   @default("[]")
  saturday  String   @default("[]")
  
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, month, year])
  @@index([userId])
  @@index([month, year])
}

// جدول الجلسات
model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  tableName String
  recordId  String
  oldData   String?
  newData   String?
  userId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tableName])
  @@index([createdAt])
}
